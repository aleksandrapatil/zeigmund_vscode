{
  "name": "Zeigmund",
  "scopeName": "source.zeigmund",
  "fileTypes": ["zeigsrt", "zeigmdl", "zeigmfst"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings_interpolated_multiline" },
    { "include": "#strings_plain_multiline" },
    { "include": "#strings_interpolated" },
    { "include": "#strings_plain" },
    { "include": "#decorator" },
    { "include": "#subexpression" },
    { "include": "#variable_file" },
    { "include": "#variable_unicode" },
    { "include": "#variable" },
    { "include": "#dotnet_types" },
    { "include": "#keywords" },
    { "include": "#import_keywords" },
    { "include": "#cmdlets" },
    { "include": "#module_commands" },
    { "include": "#parameters" },
    { "include": "#operators" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "name": "comment.block.zeigmund",
      "begin": "<​#",
      "end": "#>",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.zeigmund" } },
      "endCaptures": { "0": { "name": "punctuation.definition.comment.zeigmund" } }
    },
    "strings_interpolated": {
      "name": "string.quoted.double.zeigmund",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "include": "#variable" }, { "include": "#subexpression" }]
    },
    "strings_interpolated_multiline": {
      "name": "string.quoted.double.heredoc.zeigmund",
      "begin": "@\"",
      "end": "\"@",
      "patterns": [{ "include": "#variable" }, { "include": "#subexpression" }]
    },
    "strings_plain": {
      "name": "string.quoted.single.zeigmund",
      "begin": "'",
      "end": "'"
    },
    "strings_plain_multiline": {
      "name": "string.quoted.single.heredoc.zeigmund",
      "begin": "@'",
      "end": "'@"
    },
    "decorator": {
      "name": "variable.other.decorator.zeigmund",
      "match": "\\$\\[[A-Za-z]+-[A-Za-z]+(?:\\s+-[A-Za-z]+\\s+(?:\"[^\"]*\"|'[^']*'))*\\]"
    },
    "subexpression": {
      "name": "variable.other.subexpression.zeigmund",
      "begin": "\\$\\(",
      "end": "\\)",
      "patterns": [{ "include": "$self" }]
    },
    "variable_file": {
      "name": "variable.other.file.zeigmund",
      "match": "\\$\\{[A-Za-z]:\\\\[^}]*\\}"
    },
    "variable_unicode": {
      "name": "variable.other.unicode.zeigmund",
      "match": "\\$\\{[^}]+\\}"
    },
    "variable": {
      "name": "variable.other.zeigmund",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    "dotnet_types": {
      "name": "storage.type.dotnet.zeigmund",
      "match": "(?<!Catch\\s)\\[[A-Za-z][A-Za-z0-9.]*\\]"
    },
    "keywords": {
      "name": "keyword.control.zeigmund",
      "match": "\\b(If|Else|ElseIf|While|Until|For|ForEach|Switch|Case|Default|Try|Catch|Finally|Break|Continue|Return|Function|Class|Namespace|New-Object|Throw-Exception|Begin|Process|End|Using)\\b"
    },
    "import_keywords": {
      "name": "keyword.other.import.zeigmund",
      "match": "\\b(Import|From|As)\\b"
    },
    "cmdlets": {
      "name": "support.function.cmdlet.zeigmund",
      "match": "\\b(Add|Clear|Close|Compare|Convert|ConvertFrom|ConvertTo|Copy|Debug|Disable|Disconnect|Enable|Enter|Exit|Export|Find|Format|Get|Grant|Group|Hide|Import|Install|Invoke|Join|Limit|Lock|Measure|Merge|Mount|Move|New|Open|Optimize|Out|Pop|Protect|Publish|Push|Read|Receive|Register|Remove|Rename|Reset|Resize|Resolve|Restart|Restore|Resume|Revoke|Save|Search|Select|Send|Set|Show|Skip|Sort|Split|Start|Step|Stop|Submit|Suspend|Switch|Sync|Test|Trace|Unblock|Undo|Uninstall|Unlock|Unprotect|Unpublish|Unregister|Update|Use|Wait|Watch|Where|Write)(-[A-Za-z]+)+\\b"
    },
    "module_commands": {
      "name": "support.function.module.zeigmund",
      "match": "\\b[A-Za-z][A-Za-z0-9]*\\.[A-Za-z]+-[A-Za-z]+\\b"
    },
    "parameters": {
      "name": "variable.parameter.zeigmund",
      "match": "(?<![\\w])-[A-Za-z][A-Za-z0-9]*\\b"
    },
    "operators": {
      "name": "keyword.operator.zeigmund",
      "match": "\\+\\=|\\-\\=|\\*\\=|\\/\\=|\\+\\+|\\-\\-|\\=|\\+|\\-|\\*|\\/|>|<|\\|"
    },
    "numbers": {
      "name": "constant.numeric.zeigmund",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  }
}
